{
  "name": "@acme/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./registry": "./.adonisjs/client/registry.ts"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#app/*": "./app/*.js",
    "#core/*": "./app/core/*.js",
    "#identity/*": "./app/identity/*.js",
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0-next.2",
    "@adonisjs/core": "^7.0.0-next.13",
    "@adonisjs/cors": "^3.0.0-next.0",
    "@adonisjs/lucid": "^22.0.0-next.1",
    "@adonisjs/session": "^8.0.0-next.0",
    "@adonisjs/shield": "^9.0.0-next.1",
    "@adonisjs/static": "^2.0.0-next.1",
    "@tanstack/react-query": "^5.90.12",
    "@tuyau/core": "1.0.0-beta.5",
    "@vinejs/vine": "^4.1.0",
    "edge.js": "^6.3.0",
    "luxon": "^3.7.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0-next.20",
    "@adonisjs/tsconfig": "^2.0.0-next.3",
    "@japa/assert": "^4.1.1",
    "@japa/plugin-adonisjs": "^5.0.0-next.0",
    "@japa/runner": "^4.4.0",
    "@poppinss/ts-exec": "^1.4.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.1",
    "hot-hook": "^0.4.1-next.1",
    "pino-pretty": "^13.1.3",
    "typescript": "~5.9.3",
    "youch": "^4.1.0-beta.13"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
